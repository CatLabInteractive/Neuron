{
    "name": "catlabinteractive/neuron",
    "type": "library",
    "description": "Very light php framework. Should probably not be used.",
    "keywords": ["framework"],
    "homepage":"http://github.com/catlabinteractive/neuron",
    "license": "MIT",
    "authors" : [
        {
            "name": "Thijs Van der Schaeghe",
            "email" : "info@catlab.be",
            "homepage" : "https://www.catlab.eu/",
            "role" : "Developer"
        }
    ],

    "require" : {
        "php": ">=7.4",
        "ext-gettext" : "*",
        "nesbot/carbon": "^2.0||^3.0"
    },

    "require-dev": {
        "phpunit/phpunit": "^9.5||^10.0||^11.0"
    },

    "autoload": {
        "psr-4" : {
            "Neuron\\" : "src/Neuron/"
        }
    },

    "autoload-dev": {
        "psr-4": {
            "Neuron\\Tests\\" : "tests/"
        }
    }
}
